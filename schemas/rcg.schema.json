{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/martinopedal/agentic-alz/schemas/rcg.schema.json",
  "title": "Typed Azure Firewall Rule Collection Group",
  "description": "Provider-neutral, typed representation of a Rule Collection Group (RCG). Used by the Firewall Composer LLM stage and by the (future) MCP-driven firewall importer to round-trip rules between Azure live state and the alz-firewall-policy/lib/ working tree without ever pasting raw Azure JSON into Terraform.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "name", "priority", "rule_collections"],
  "properties": {
    "schema_version": { "type": "string", "const": "1" },
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{1,61}[a-z0-9]$",
      "description": "RCG name; lowercase kebab-case, 3-63 chars."
    },
    "description": { "type": "string", "maxLength": 200 },
    "priority": {
      "type": "integer",
      "minimum": 100,
      "maximum": 65000,
      "description": "RCG priority within the policy (Azure Firewall valid range)."
    },
    "rule_collections": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/rule_collection" }
    }
  },
  "$defs": {
    "rule_collection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "kind", "priority", "action", "rules"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,61}[a-z0-9]$" },
        "kind": { "type": "string", "enum": ["network", "application"] },
        "priority": { "type": "integer", "minimum": 100, "maximum": 65000 },
        "action": { "type": "string", "enum": ["Allow", "Deny"] },
        "rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              { "$ref": "#/$defs/network_rule" },
              { "$ref": "#/$defs/application_rule" }
            ]
          }
        }
      }
    },
    "network_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "kind", "protocols", "destination_ports"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,61}[a-z0-9]$" },
        "kind": { "type": "string", "const": "network" },
        "description": { "type": "string", "maxLength": 200 },
        "protocols": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "enum": ["TCP", "UDP", "ICMP", "Any"] }
        },
        "source_addresses": {
          "type": "array",
          "items": { "$ref": "#/$defs/cidr_or_ip" }
        },
        "source_ip_groups": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "destination_addresses": {
          "type": "array",
          "items": {
            "anyOf": [
              { "$ref": "#/$defs/cidr_or_ip" },
              { "$ref": "#/$defs/service_tag" }
            ]
          }
        },
        "destination_ip_groups": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "destination_fqdns": {
          "type": "array",
          "items": { "$ref": "#/$defs/fqdn" }
        },
        "destination_ports": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/port_or_range" }
        }
      }
    },
    "application_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "kind", "protocols"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,61}[a-z0-9]$" },
        "kind": { "type": "string", "const": "application" },
        "description": { "type": "string", "maxLength": 200 },
        "protocols": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "port"],
            "properties": {
              "type": { "type": "string", "enum": ["Http", "Https", "Mssql"] },
              "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
            }
          }
        },
        "source_addresses": {
          "type": "array",
          "items": { "$ref": "#/$defs/cidr_or_ip" }
        },
        "source_ip_groups": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "destination_fqdns": {
          "type": "array",
          "items": { "$ref": "#/$defs/fqdn" }
        },
        "destination_fqdn_tags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "cidr_or_ip": {
      "type": "string",
      "pattern": "^([0-9]{1,3}\\.){3}[0-9]{1,3}(/([0-9]|[12][0-9]|3[0-2]))?$",
      "description": "IPv4 address or CIDR. Wildcards ('*') are forbidden by policy."
    },
    "service_tag": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9.]{1,63}$",
      "description": "Azure service tag (e.g. 'AzureContainerRegistry', 'Sql')."
    },
    "fqdn": {
      "type": "string",
      "minLength": 1,
      "maxLength": 253,
      "pattern": "^(\\*\\.)?([a-zA-Z0-9]([a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?\\.)+[a-zA-Z]{2,}$",
      "description": "Fully-qualified domain name. At most one leftmost '*.' wildcard label is allowed; '*' alone is forbidden, matching policies/firewall_rules.rego."
    },
    "port_or_range": {
      "type": "string",
      "pattern": "^([0-9]{1,5})(-[0-9]{1,5})?$",
      "description": "Single port or 'low-high' range; wildcards forbidden."
    }
  }
}
