# CODEOWNERS for agentic-alz
#
# This file is intentionally minimal in v1. Replace `@martinopedal` with the
# real owners (platform team for orchestrator/templates, NetSec for any
# firewall-adjacent code) before going to production. The sibling
# `alz-firewall-policy` repo MUST set NetSec as CODEOWNER on `policies/base/`
# and `lib/`.

* @martinopedal

/orchestrator/                @martinopedal
/templates/                   @martinopedal
/policies/                    @martinopedal
/firewall-policy/             @martinopedal
/.github/workflows/           @martinopedal
/bootstrap/                   @martinopedal

# Squad bootstrap: roadmap + script changes change which work the cloud agent
# can pick up, so they require platform-team review.
/ROADMAP.md                                 @martinopedal
/scripts/squad_bootstrap.py                 @martinopedal
/.github/workflows/squad.yml                @martinopedal
/.github/workflows/copilot-setup-steps.yml  @martinopedal
/schemas/roadmap.schema.json                @martinopedal

# Sensitive allowlists. Both files declare what LLM models / MCP servers the
# orchestrator may reach at runtime. Adding an entry — especially an MCP
# server in `mode: write` — must go through NetSec review.
/docs/models.allowlist.yaml                 @martinopedal
/docs/mcp.allowlist.yaml                    @martinopedal
/orchestrator/agentic_alz/llm/              @martinopedal
/orchestrator/agentic_alz/mcp/              @martinopedal
/policies/mcp_allowlist.rego                @martinopedal
